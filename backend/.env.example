DATABASE_URL=postgresql://user:password@host:5432/dbname

BOT_TOKEN=your_telegram_bot_token
WEBAPP_URL=https://your-webapp-url.com
PORT=4000

# MoySklad API
# MOSKLAD_TOKEN: base64 of "login:password"
MOSKLAD_TOKEN=your_moysklad_token
MOSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2

# Reminder days after order (comma-separated)
REMINDER_DAYS_AFTER_ORDER=1,2,3,6

# Admin Telegram IDs (comma-separated)
ADMIN_TELEGRAM_IDS=

# Test mode: when true, sends stats and debt reminder every 2 min to TEST_TELEGRAM_ID.
TEST_MODE=false
TEST_TELEGRAM_ID=

# Daily report hour (24h) and timezone offset from UTC
REPORT_HOUR=20
REPORT_TIMEZONE_OFFSET=5

# MoySklad custom attribute UUIDs for driver info on shipments/demands
# Find UUIDs: GET https://api.moysklad.ru/api/remap/1.2/entity/demand/metadata
MOSKLAD_DRIVER_MODEL_ATTRS=
MOSKLAD_DRIVER_NUMBER_ATTRS=

# MoySklad custom attribute UUIDs for counterparty Telegram info
# Find UUIDs: GET https://api.moysklad.ru/api/remap/1.2/entity/counterparty/metadata
MOSKLAD_COUNTERPARTY_USERNAME_ATTR=
MOSKLAD_COUNTERPARTY_TELEGRAM_ID_ATTR=

# MoySklad custom attribute UUIDs for counterparty default address (set once on registration)
MOSKLAD_COUNTERPARTY_LOCATION_ATTR=
MOSKLAD_COUNTERPARTY_ADDRESS_ATTR=

# Counterparty flag/checkbox attribute - when it becomes true, notify the user via Telegram
# Find UUID: GET https://api.moysklad.ru/api/remap/1.2/entity/counterparty/metadata
MOSKLAD_COUNTERPARTY_FLAG_ATTR=

# MoySklad custom attribute UUIDs for demand delivery info (set per order)
# Find UUIDs: GET https://api.moysklad.ru/api/remap/1.2/entity/demand/metadata
MOSKLAD_ORDER_LOCATION_ATTR=
MOSKLAD_ORDER_ADDRESS_ATTR=
MOSKLAD_ORDER_NOTE_ATTR=
MOSKLAD_DELIVERY_METHOD_ATTR=
MOSKLAD_DELIVERY_METHOD_PICKUP=
MOSKLAD_DELIVERY_METHOD_DELIVERY=

# Apartment/floor/entry/intercom details field
ORDER_ADDRESS_DETAILS=
COUNTERPARTY_ADDRESS_DETAILS=

# Override default org/store (optional — auto-detected if not set)
MOSKLAD_ORGANIZATION_ID=
MOSKLAD_STORE_ID=

# Shared API key for comfort-textile-dashboard → bot communication
DASHBOARD_API_KEY=
